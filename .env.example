# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
VITE_APP_URL=https://your-domain.com
VITE_APP_ID=
COMPANY_TIMEZONE=America/Denver

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/dbname

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ── Stripe (live) ─────────────────────────────────────────────────────────────
STRIPE_TEST_MODE=false
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Stripe (test) — set STRIPE_TEST_MODE=true to use these instead ────────────
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_TEST_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_TEST_PUBLISHABLE_KEY=pk_test_...

# ── Cloudflare R2 (file storage) ─────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Twilio (SMS) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Calendly ─────────────────────────────────────────────────────────────────
CALENDLY_API_TOKEN=
CALENDLY_WEBHOOK_SIGNING_KEY=

# ── Feature Flags ────────────────────────────────────────────────────────────
# Set to false to stop all outbound check-in emails (cron). UI and data are unaffected.
# Toggle back to true (or remove the variable) to re-enable.
CHECKIN_ENABLED=true

# ── Logging (optional) ───────────────────────────────────────────────────────
LOG_LEVEL=info
SERVICE_NAME=health-coach-protocol
DISABLE_CONSOLE_LOGS=false
# DATADOG_API_KEY=
# LOGGLY_TOKEN=
